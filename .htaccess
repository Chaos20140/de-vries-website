# de Vries – Apache-Konfiguration für Strato

# www -> ohne www (kanonisch: https://andreasdevries.de).
# HTTPS bitte zusätzlich im Strato-Panel aktivieren (SSL-Zertifikat + "immer HTTPS").
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^ https://andreasdevries.de%{REQUEST_URI} [L,R=301]

# Sinnvolle Standard-Sicherheitsheader (die Content-Security-Policy steht bereits in den Seiten).
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Statische Dateien cachen. Der ?v=-Cache-Buster an CSS/JS sorgt dafür, dass
# Aktualisierungen trotzdem sofort ankommen.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType font/woff2 "access plus 365 days"
</IfModule>

# Verzeichnis-Listing aus, korrekte Startseite
Options -Indexes
DirectoryIndex index.html
